PORT=3001

# Option 1: OpenAI (default model: gpt-4o-mini)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Option 2: OpenRouter — use any model (Claude, Gemini, Llama, etc.)
# Get key: https://openrouter.ai/keys | Models: https://openrouter.ai/models
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=anthropic/claude-3-haiku
# Or: google/gemini-flash-1.5, meta-llama/llama-3.1-8b-instruct, etc.

# Override model for either provider (e.g. gpt-4o or a specific OpenRouter id)
# AI_MODEL=gpt-4o
